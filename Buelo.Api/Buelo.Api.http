@Buelo.Api_HostAddress = http://localhost:5238/api

POST {{Buelo.Api_HostAddress}}/report/render
Content-Type: application/json

{
  "template": "Document.Create(c => c.Page(p => p.Content().Text((string)data.name)).Bold()).GeneratePdf()",
  "fileName": "hello.pdf",
  "data": { "name": "World" }
}
